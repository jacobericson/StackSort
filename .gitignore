# Whitelist: ignore everything, then allow known paths.
# To commit a new top-level path, add an explicit `!/path` line.

# --- Root ---
/*
!/.gitattributes
!/.gitignore
!/LICENSE
!/README.md
!/StackSort.vcxproj
!/src/
!/stacksort.gif
!/tests/

# --- tests/: ---
/tests/*
!/tests/analyze.py
!/tests/basins.py
!/tests/bistability.py
!/tests/generate_corpus.py
!/tests/loaders.py
!/tests/run_matrix.py
!/tests/configs/
!/tests/corpus/
!/tests/harness/

# --- tests/configs/: ---
/tests/configs/*
!/tests/configs/baseline.ini

# --- tests/corpus/: ---
/tests/corpus/*
!/tests/corpus/*.txt

# --- tests/harness/: only C++ source ---
/tests/harness/*
!/tests/harness/*.cpp
!/tests/harness/*.h
